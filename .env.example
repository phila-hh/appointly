# Database
DATABASE_URL="postgresql://appointly_user:appointly_password@localhost:5433/appointly?schema=public"
  
# Next Auth
# Generate with `npx auth secret`
AUTH_SECRET="replace-with-a-secure-random-string"
AUTH_URL="http://localhost:3000"

# Google OAuth
# Get these at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID='your-google-client-id.apps.google.usercontent.com'
GOOGLE_CLIENT_SECRET='your-google-client-secret'

# Resend Email
# Get your key at: https://resend.com/api-keys
# RESEND_API_KEY='re_your_api_key_here'

# Email Form Address (optional — defaults to onboarding@resend.dev)
# Use your verified domain in production
# EMAIL_FROM="Appointly <noreplay@appointly.com>"

# Email Configuration (Gmail SMTP — for development.demo)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-16-char-app-password"
EMAIL_FROM="Appointly <your-gmail@gmail.com>"

# Chapa Payment Gateway
CHAPA_SECRET_KEY="your-chapa-test-key-here"

# Hugging Face Inference API (free tier)
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN="hf_your_token_here"

# OpenRouter API
# Get your key at:  https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-your-key-here"

# Cron Job Security
# Generate with openssl rand -hex 32
CRON_SECRET="your-secure-cron-secret-here"
