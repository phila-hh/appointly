generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Core User model represents every person on the platform — customers,
/// business owner, and admins. Extended from the NextAuth base schema.
model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  image            String?
  password         String?
  phone            String?
  role             Role      @default(CUSTOMER)
  emailVerified    DateTime?
  emailPreferences Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // -- Relations --
  accounts       Account[]
  adminAuditLogs AdminAuditLog[]
  bookings       Booking[]
  business       Business?
  favorites      Favorite[]
  notifications  Notification[]
  reviews        Review[]
  sessions       Session[]

  @@map("users")
}

/// Platform-wide settings managed by admins.
model PlatformSettings {
  id                    String   @id @default(cuid())
  defaultCommissionRate Float    @default(0.10)
  payoutSchedule        String   @default("MONTHLY")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("platform_settings")
}

/// Immutable log of sensitive admin actions for accountability.
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

/// OAuth provider linked to a user (e.g., Google, Github)
/// A single user may have multiple linked accounts.
/// Required by NextAuth.js — do not modify field names
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/// Active user session, Tracks logged-in users and session expiry.
/// Required by NextAuth.js — do not modify field names
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

/// Token used for email-based verification (e.g., magic links, email confirm)
/// Required by NextAuth.js — do not modify field names
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// A business profile on the platform. Each business is owned by exactly
/// one user (the BUSINESS_OWNER). Contains all public-facing information
/// customer see when browsing.
model Business {
  id                    String           @id @default(cuid())
  ownerId               String           @unique
  name                  String
  slug                  String           @unique
  description           String?
  category              BusinessCategory
  phone                 String?
  email                 String?
  website               String?
  address               String?
  city                  String?
  state                 String?
  zipCode               String?
  image                 String?
  coverImage            String?
  isActive              Boolean          @default(true)
  announcement          String?          @db.Text /// Short public announcement shown as a banner on a business page
  announcementExpiresAt DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  // -- Relations --
  bookings      Booking[]
  BusinessHours BusinessHours[]
  owner         User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  commissions   Commission[]
  favorites     Favorite[]
  payouts       Payout[]
  reviews       Review[]
  services      Service[]
  staff         Staff[]

  // -- Indexes --
  @@index([category])
  @@index([city])
  @@index([isActive])
  @@map("businesses")
}

/// A service offered by a business (e.g., "Men's Haircut", "Deep Tissue Massage").
/// Each service has a price and a duration, which are used to calculate
/// available time slots and booking costs.
model Service {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String
  price       Decimal  @db.Decimal(10, 2)
  duration    Int
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // -- Relations --
  bookings      Booking[]
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffServices StaffService[]

  // -- Indexes --
  @@index([businessId])
  @@index([isActive])
  @@map("services")
}

/// Operating hours for a specific day of the week. Each business can have
/// one entry per day (enforced by the compound unique constraint).
/// Times are stored as strings in "HH:mm" format (24-hour clock) and are
/// always interpreted in the business's local timezone
model BusinessHours {
  id         String    @id @default(cuid())
  businessId String
  dayOfWeek  DayOfWeek
  openTime   String
  closeTime  String
  isClosed   Boolean   @default(false)
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
  @@index([businessId])
  @@map("business_hours")
}

/// An appointment booked by a customer for a specific service at a business.
/// The date and time fields are stored separately to simplify scheduling logic
/// and avoid timezone conversion issues.
model Booking {
  id                   String        @id @default(cuid())
  customerId           String
  businessId           String
  serviceId            String
  staffId              String?
  date                 DateTime      @db.Date
  startTime            String
  endTime              String
  status               BookingStatus @default(PENDING)
  notes                String?
  totalPrice           Decimal       @db.Decimal(10, 2)
  cancellationDeadline DateTime?
  cancellationFee      Decimal       @default(0) @db.Decimal(10, 2)
  isCancellable        Boolean       @default(true)
  rescheduleCount      Int           @default(0)
  warningEmailSentAt   DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // -- Relations --
  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer   User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service    Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff      Staff?      @relation(fields: [staffId], references: [id])
  commission Commission?
  payment    Payment?
  review     Review?

  // -- Indexes --
  @@index([customerId])
  @@index([businessId])
  @@index([serviceId])
  @@index([date])
  @@index([status])
  @@index([businessId, date])
  @@index([customerId, status])
  @@index([staffId])
  @@map("bookings")
}

/// Payment record for a booking. Stores Chapa transaction details.
/// Separated from booking to isolate payment concerns and support
/// potential future payment provider changes
model Payment {
  id                  String        @id @default(cuid())
  bookingId           String        @unique
  amount              Decimal       @db.Decimal(10, 2)
  status              PaymentStatus @default(PENDING)
  chapaTransactionRef String?       @unique
  refundStatus        String?
  refundedAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // -- Relations --
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // -- Indexes --
  @@index([status])
  @@map("payments")
}

/// Commission line item generated from a paid booking.
model Commission {
  id               String           @id @default(cuid())
  bookingId        String           @unique
  businessId       String
  payoutId         String?
  grossAmount      Decimal          @db.Decimal(10, 2)
  commissionRate   Float
  commissionAmount Decimal          @db.Decimal(10, 2)
  netAmount        Decimal          @db.Decimal(10, 2)
  status           CommissionStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // -- Relations --
  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payout   Payout?  @relation(fields: [payoutId], references: [id])

  // -- Indexes --
  @@index([businessId, status])
  @@index([payoutId])
  @@map("commissions")
}

/// Business payout batch for a specific period.
model Payout {
  id              String       @id @default(cuid())
  businessId      String
  amount          Decimal      @db.Decimal(10, 2)
  commissionTotal Decimal      @db.Decimal(10, 2)
  grossTotal      Decimal      @db.Decimal(10, 2)
  period          String
  status          PayoutStatus @default(PENDING)
  paidAt          DateTime?
  reference       String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // -- Relations --
  commissions Commission[]
  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  // -- Indexes --
  @@index([businessId, period])
  @@index([status])
  @@map("payouts")
}

/// A staff member / employee who works at a business and can be
/// assigned to perform specific services. Each staff member has their
/// own schedule (StaffHours) independent of the business's operating hours.
model Staff {
  id         String   @id @default(cuid())
  businessId String
  name       String
  email      String?
  phone      String?
  image      String?
  title      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // -- Relations --
  bookings Booking[]
  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  hours    StaffHours[]
  services StaffService[]

  // -- Indexes --
  @@index([businessId])
  @@map("staff")
}

/// Join table linking staff members to the services they can perform.
/// A staff member can perform multiple services, and a service can be
/// performed by multiple staff members (many-to-many).
model StaffService {
  id        String @id @default(cuid())
  staffId   String
  serviceId String

  // -- Relations --
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  // -- Constraints --
  @@unique([staffId, serviceId])
  // -- Indexes --
  @@index([staffId])
  @@index([serviceId])
  @@map("staff_services")
}

/// Individual working hours for a staff member on a specific day.
/// Mirrors the BusinessHours model but scoped to a single staff member.
/// Staff hours should be a subset of business hours — a staff member
/// cannot work when the business is closed.
model StaffHours {
  id        String    @id @default(cuid())
  staffId   String
  dayOfWeek DayOfWeek
  openTime  String
  closeTime String
  isClosed  Boolean   @default(false)

  // -- Relations --
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  // -- Constraints --
  @@unique([staffId, dayOfWeek])
  // -- Indexes --
  @@index([staffId])
  @@map("staff_hours")
}

/// A customer review for a business, tied to a specific completed booking.
/// Linking reviews to booking ensures only customers who actually received
/// the service can leave feedback. One review per booking is enforced by
/// the unique constraint on the bookingId.
///
/// Sentiment analysis:
/// - sentimentLabel: "positive" | "neutral" | "negative" (from Hugging Face)
/// - sentimentScore: 0.0 to 1.0 confidence score
/// - Both are nullable — null means analysis was not performed or failed
///
/// Business reply:
///   - businessReply: the owner's public response to this review
///   - businessReplyAt: when the reply was posted (or last edited)
///   - Both are nullable — null means no reply has been posted yet
model Review {
  id              String   @id @default(cuid())
  customerId      String
  businessId      String
  bookingId       String   @unique
  rating          Int
  comment         String?
  sentimentLabel  String?
  sentimentScore  Float?
  businessReply   String?  @db.Text
  businessReplyAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // -- Relations --
  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer User     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // -- Indexes --
  @@index([businessId])
  @@index([customerId])
  @@index([rating])
  @@index([sentimentLabel])
  @@map("reviews")
}

/// Customer's favorited businesses for quick access.
/// A customer can favorite multiple businesses, and a business can be
/// favorited by multiple customers (many-to-many relationship).
model Favorite {
  id         String   @id @default(cuid())
  customerId String
  businessId String
  createdAt  DateTime @default(now())

  // -- Relations --
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer User     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // -- Constraints --
  @@unique([customerId, businessId])
  // -- Indexes --
  @@index([customerId])
  @@index([businessId])
  @@map("favorites")
}

/// In-app notification delivered to a user when a significant event occurs.
///
/// Type values (not an enum — kept as String for forward compatibility):
///   Customer:       BOOKING_CONFIRMED | BOOKING_CANCELLED | BOOKING_RESCHEDULED |
///                   PAYMENT_REFUNDED | REVIEW_REPLY | REVIEW_REQUEST
///   Business owner: NEW_BOOKING | BOOKING_CANCELLED | BOOKING_RESCHEDULED |
///                   REVIEW_RECEIVED | PAYOUT_PROCESSED | OVERDUE_BOOKING
///   Admin:          NEW_BUSINESS | PAYOUT_PENDING | REFUND_ISSUED
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // -- Relations --
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // -- Indexes --
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

/// The role a user holds within the platform.
enum Role {
  CUSTOMER
  BUSINESS_OWNER
  ADMIN
}

/// Category that describes the type of business
enum BusinessCategory {
  BARBERSHOP
  SALON
  SPA
  FITNESS
  DENTAL
  MEDICAL
  TUTORING
  CONSULTING
  PHOTOGRAPHY
  AUTOMOTIVE
  HOME_SERVICES
  PET_SERVICES
  OTHER
}

/// Day of week for business operating hours
enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

/// Lifecycle status of booking
enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

/// Status of a payment transaction
enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

/// Lifecycle state of a commission line item.
enum CommissionStatus {
  PENDING
  INCLUDED_IN_PAYOUT
  PAID_OUT
}

/// Lifecycle state of a payout batch.
enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}
